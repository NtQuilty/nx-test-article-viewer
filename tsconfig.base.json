{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["development"],
    "paths": {
      "api-client": ["packages/shared/api-client/src/index.ts"],
      "data-access": ["packages/articles/data-access/src/index.ts"],
      "router": ["packages/shared/router/src/index.ts"],
      "ui": ["packages/shared/ui/src/index.ts"]
    }
  }
}
